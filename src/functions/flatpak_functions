{
    local selections
    selections=$(yad --list \
        --title="Resultados da pesquisa" \
        --class="$APP_NAME" \
        --window-icon="$FLATPAK_LOGO" \
        --no-markup \
        --grid-lines=both \
        --checklist \
        --expand-column=0 \
        --column="Instalar" \
        --column="ID"\
        --column="NOME" \
        --column="DESCRIÇÃO" \
        --column="VERSÃO"  \
        --column="RAMO" \
        --width=700 \
        --height=300 \
        --button="OK" \
        "$@"
    ) 
    
    [[ -z $selections ]] && return
    parse_selections "$selections" "install"
}


function get_flatpaks_list
{
    local result_args=()
    read_flatpak_results_with_loading \
        "Procurando" \
        "Aguarde enquanto procura o aplicativo" \
        push_checklist_row result_args search "$1"
    
    (( ${#result_args[@]} == 0 )) &&
    {
        show_info "Sem correspondência" "$NO_MATCH_INFO"
        return
    }
    
    show_flatpak_search_list "${result_args[@]}"
}


function validate_search_term
{
    local term=$1
    
    # Remove caracteres estranhos (*_?$ etc..).
    # Após, o read pega a primeira palavra para term
    # e descarta o resto (vai para _).
    # Não é a prova de "estupidez..", o flatpak
    # permite coisas como: flatpak search 8 e
    # pior: se digitar isso o flatpak encontra resultados..
    term=${term//[^[:space:][:alpha:][:digit:]]\.-/}
    read -r term _ <<< "$term"
    
    [[ -z $term ]] && return

    get_flatpaks_list "${term,,}"
}


function get_search_term
{
    # Entry provavelmente é mais apropriado,
    # mas pelo que testei o --entry não parece
    # aceitar --fixed.
    local term
    term=$(yad --form \
        --title="Procurar" \
        --class="$APP_NAME" \
        --window-icon="$FLATPAK_LOGO" \
        --field="Digite o nome do aplicativo:" \
        --fixed \
        --button="OK" \
        --button="Cancelar"
    ) ||
    return
    
    validate_search_term "${term%|}"
}
