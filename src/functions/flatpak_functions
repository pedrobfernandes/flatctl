function get_flatpaks_list
{
    local result_args=()
    read_flatpak_results_with_loading \
        "$(t TITLE_SEARCH_LOADING)" \
        "$(t MSG_LOADING)" \
        push_checklist_row result_args search "$1"
        
    [[ -f "$APP_ALIVE_FILE" ]] || return
    
    (( ${#result_args[@]} == 0 )) &&
    {
        show_info "$(t TITLE_NO_MATCH)" "<span $BOLD_DESCRIPTION>$(t MSG_NO_MATCH)</span>"
        return
    }
    
    show_flatpak_search_list "${result_args[@]}"
}


function validate_search_term
{
    local term=$1
    term=${term//[^[:space:][:alpha:][:digit:]]\.-/}
    read -r term _ <<< "$term"
    
    [[ -z $term ]] && return

    get_flatpaks_list "${term,,}"
}


function get_search_term
{
    # Entry provavelmente é mais apropriado,
    # mas pelo que testei o --entry não parece
    # aceitar --fixed.
    local tmpfifo
    tmpfifo=$(create_fifo) ||
    {
        show_info "$(t TITLE_ERROR)" "$(t MSG_FAILED_START_OPERATION)"
        return 1
    }
    
    trap 'cleanup_fifo "$tmpfifo"' RETURN
    
    yad --form \
        --title="$(t TITLE_SEARCH)" \
        --class="$APP_NAME" \
        --window-icon="$FLATPAK_LOGO" \
        --field="$(t MSG_SEARCH_APP)" \
        --fixed \
        --button="OK" \
        --button="$(t BTN_CANCEL)" > "$tmpfifo" &
    
    local yad_pid=$!
    register_yad_pid "$yad_pid"
    
    local term
    term=$(<"$tmpfifo")
    
    wait "$yad_pid"
    
    validate_search_term "${term%|}"
}
