# OPÇÕES DA AÇÕES DO FLATPAK
FLATPAK_LIST_APP=(list --system --app)
FLATPAK_LIST_RUNTIME=(list --system --runtime)
FLATPAK_LIST_BOTH=(list --system)

FLATPAK_INSTALL_CMD=(install --system --assumeyes flathub)
FLATPAK_UNINSTALL_CMD=(uninstall --system --assumeyes)
FLATPAK_UPDATE_CMD=(update --system --assumeyes)


# COLUNAS DE MOSTRAGEM DO FLATPAK
FLATPAK_COLUMNS=(--columns=application,name,description,version,branch)


# MARKUP DE TEXTO
TITLE_STYLE="weight='bold' font='20'"
DESCRIPTION_STYLE="font='12'"
BOLD_DESCRIPTION="font='12' weight='bold'"


# ICONES
ICON_INFO="$BASE_DIR/assets/images/info-icon.svg"
ICON_INSTALL="$BASE_DIR/assets/images/install-icon.png"
ICON_UNINSTALL="$BASE_DIR/assets/images/uninstall-icon.png"
ICON_UPDATE="$BASE_DIR/assets/images/update-icon.png"
ICON_SEARCH="$BASE_DIR/assets/images/search-icon.png"
ICON_LIST="$BASE_DIR/assets/images/list-icon.png"
ICON_MAINTENANCE="$BASE_DIR/assets/images/maintenance-icon.png"
FLATPAK_LOGO="$BASE_DIR/assets/images/flatpak-logo.png"
